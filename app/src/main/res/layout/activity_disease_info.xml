<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Фото -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardBackgroundColor="#1E1A1A"
            app:cardElevation="0dp">

            <ImageView
                android:id="@+id/diseaseImageView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_launcher_foreground"
                android:contentDescription="Фото растения" />

        </androidx.cardview.widget.CardView>

        <!-- Кнопки -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/diseaseBtnCamera"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="📷  Камера"
                android:backgroundTint="#2D1A1A"
                android:textColor="#FF7043"
                style="@style/Widget.Material3.Button.OutlinedButton" />

            <Button
                android:id="@+id/diseaseBtnGallery"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="🖼  Галерея"
                android:backgroundTint="#2A2A2A"
                android:textColor="#AAAAAA"
                style="@style/Widget.Material3.Button.OutlinedButton" />

        </LinearLayout>

        <!-- Прогресс / статус -->
        <ProgressBar
            android:id="@+id/diseaseProgressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:visibility="gone"
            android:indeterminateTint="#FF7043"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/diseaseTvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Загрузка модели..."
            android:textColor="#666666"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginBottom="12dp"/>

        <!-- Карточка результата -->
        <LinearLayout
            android:id="@+id/diseaseCardResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvDiseaseName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvDiseaseConfidence"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="#666666"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/tvPathogen"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="#AAAAAA"
                android:layout_marginBottom="2dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">

                <TextView
                    android:id="@+id/tvSeverity"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="12sp"
                    android:textColor="#FF7043"/>

                <TextView
                    android:id="@+id/tvSpread"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="12sp"
                    android:textColor="#888888"/>

            </LinearLayout>

            <TextView
                android:id="@+id/tvUrgency"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#2A2A2A" android:layout_marginBottom="12dp"/>

            <!-- Симптомы -->
            <LinearLayout android:id="@+id/sectionSymptoms"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginBottom="10dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="🔍 Симптомы" android:textSize="14sp"
                    android:textStyle="bold" android:textColor="#FF7043"
                    android:layout_marginBottom="4dp"/>
                <TextView android:id="@+id/tvSymptoms"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textSize="13sp" android:textColor="#AAAAAA"
                    android:lineSpacingMultiplier="1.4"/>
            </LinearLayout>

            <!-- Причины -->
            <LinearLayout android:id="@+id/sectionCauses"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginBottom="10dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="⚡ Причины" android:textSize="14sp"
                    android:textStyle="bold" android:textColor="#FFA726"
                    android:layout_marginBottom="4dp"/>
                <TextView android:id="@+id/tvCauses"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textSize="13sp" android:textColor="#AAAAAA"
                    android:lineSpacingMultiplier="1.4"/>
            </LinearLayout>

            <!-- Лечение -->
            <LinearLayout android:id="@+id/sectionTreatment"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginBottom="10dp"
                android:background="#1F1A10" android:padding="12dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="💊 Лечение" android:textSize="14sp"
                    android:textStyle="bold" android:textColor="#FFA726"
                    android:layout_marginBottom="4dp"/>
                <TextView android:id="@+id/tvTreatment"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textSize="13sp" android:textColor="#CCCCCC"
                    android:lineSpacingMultiplier="1.5"/>
            </LinearLayout>

            <!-- Профилактика -->
            <LinearLayout android:id="@+id/sectionPrevention"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginBottom="10dp"
                android:background="#101A10" android:padding="12dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="🛡 Профилактика" android:textSize="14sp"
                    android:textStyle="bold" android:textColor="#4CAF50"
                    android:layout_marginBottom="4dp"/>
                <TextView android:id="@+id/tvPrevention"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textSize="13sp" android:textColor="#CCCCCC"
                    android:lineSpacingMultiplier="1.5"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvDiseaseOther"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#555555"
                android:lineSpacingMultiplier="1.4"
                android:visibility="gone"/>

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Диагностика носит рекомендательный характер. При серьёзных заболеваниях обратитесь к агроному."
            android:textSize="10sp"
            android:textColor="#444444"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"/>

    </LinearLayout>
</ScrollView>
