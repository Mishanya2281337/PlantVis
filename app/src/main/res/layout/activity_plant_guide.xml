<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F8E9">

    <!-- ЭКРАН 1 — СПИСОК -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/guideScrollList"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible">

        <LinearLayout
            android:id="@+id/guideListContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp" />

    </androidx.core.widget.NestedScrollView>

    <!-- ЭКРАН 2 — КАРТОЧКА -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/guideCardContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F1F8E9"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Фотогалерея -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:background="#C8E6C9">

                <ImageView
                    android:id="@+id/guidePhotoView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:contentDescription="Фото растения" />

                <ProgressBar
                    android:id="@+id/guidePhotoProgress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:visibility="gone" />

                <ImageButton
                    android:id="@+id/guideBtnPhotoLeft"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="center_vertical|start"
                    android:layout_marginStart="8dp"
                    android:background="#99000000"
                    android:padding="10dp"
                    android:src="@android:drawable/ic_media_previous"
                    android:tint="#FFFFFF"
                    android:contentDescription="Назад"
                    android:visibility="invisible" />

                <ImageButton
                    android:id="@+id/guideBtnPhotoRight"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="center_vertical|end"
                    android:layout_marginEnd="8dp"
                    android:background="#99000000"
                    android:padding="10dp"
                    android:src="@android:drawable/ic_media_next"
                    android:tint="#FFFFFF"
                    android:contentDescription="Вперёд"
                    android:visibility="invisible" />

                <LinearLayout
                    android:id="@+id/guidePhotoDots"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="10dp"
                    android:orientation="horizontal" />

            </FrameLayout>

            <!-- Основная информация -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:elevation="2dp">

                <Button
                    android:id="@+id/guideBtnBack"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="← Все растения"
                    android:backgroundTint="#E8F5E9"
                    android:textColor="#2E7D32"
                    android:textSize="12sp"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/guideDetailName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="#1B5E20"
                    android:layout_marginBottom="2dp" />

                <TextView
                    android:id="@+id/guideDetailSci"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textStyle="italic"
                    android:textColor="#888888"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:id="@+id/guideDetailFamily"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="12sp"
                        android:textColor="#777777" />

                    <TextView
                        android:id="@+id/guideDetailOrigin"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="12sp"
                        android:textColor="#777777"
                        android:gravity="end" />

                </LinearLayout>

                <TextView
                    android:id="@+id/guideDetailDifficulty"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#388E3C"
                    android:layout_marginBottom="10dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E8F5E9"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:id="@+id/guideDetailDesc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textColor="#333333"
                    android:lineSpacingMultiplier="1.5" />

            </LinearLayout>

            <!-- Блок ухода -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🌱 Уход"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#1B5E20"
                    android:layout_marginBottom="16dp" />

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="☀️ Освещение" android:textSize="13sp" android:textStyle="bold" android:textColor="#2E7D32" android:layout_marginBottom="4dp" />
                <TextView android:id="@+id/guideCareLight" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="13sp" android:textColor="#444444" android:lineSpacingMultiplier="1.4" android:layout_marginBottom="14dp" />

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="💧 Полив" android:textSize="13sp" android:textStyle="bold" android:textColor="#2E7D32" android:layout_marginBottom="4dp" />
                <TextView android:id="@+id/guideCareWatering" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="13sp" android:textColor="#444444" android:lineSpacingMultiplier="1.4" android:layout_marginBottom="14dp" />

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="💨 Влажность" android:textSize="13sp" android:textStyle="bold" android:textColor="#2E7D32" android:layout_marginBottom="4dp" />
                <TextView android:id="@+id/guideCareHumidity" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="13sp" android:textColor="#444444" android:lineSpacingMultiplier="1.4" android:layout_marginBottom="14dp" />

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="🌡️ Температура" android:textSize="13sp" android:textStyle="bold" android:textColor="#2E7D32" android:layout_marginBottom="4dp" />
                <TextView android:id="@+id/guideCareTemperature" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="13sp" android:textColor="#444444" android:lineSpacingMultiplier="1.4" android:layout_marginBottom="14dp" />

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="🪴 Грунт" android:textSize="13sp" android:textStyle="bold" android:textColor="#2E7D32" android:layout_marginBottom="4dp" />
                <TextView android:id="@+id/guideCareSoil" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="13sp" android:textColor="#444444" android:lineSpacingMultiplier="1.4" android:layout_marginBottom="14dp" />

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="🌿 Подкормка" android:textSize="13sp" android:textStyle="bold" android:textColor="#2E7D32" android:layout_marginBottom="4dp" />
                <TextView android:id="@+id/guideCareFertilizing" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="13sp" android:textColor="#444444" android:lineSpacingMultiplier="1.4" android:layout_marginBottom="14dp" />

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="🔄 Пересадка" android:textSize="13sp" android:textStyle="bold" android:textColor="#2E7D32" android:layout_marginBottom="4dp" />
                <TextView android:id="@+id/guideCareRepotting" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="13sp" android:textColor="#444444" android:lineSpacingMultiplier="1.4" android:layout_marginBottom="14dp" />

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="🌱 Размножение" android:textSize="13sp" android:textStyle="bold" android:textColor="#2E7D32" android:layout_marginBottom="4dp" />
                <TextView android:id="@+id/guideCarePropagation" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="13sp" android:textColor="#444444" android:lineSpacingMultiplier="1.4" android:layout_marginBottom="14dp" />

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E8F5E9" android:layout_marginBottom="12dp" />

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="⚠️ Токсичность" android:textSize="13sp" android:textStyle="bold" android:textColor="#E65100" android:layout_marginBottom="4dp" />
                <TextView android:id="@+id/guideCareToxicity" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="13sp" android:textColor="#555555" android:lineSpacingMultiplier="1.4" android:layout_marginBottom="8dp" />

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="32dp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</FrameLayout>
