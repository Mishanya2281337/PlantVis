<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F8E9"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Заголовок -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🌿 PlantVis"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#2E7D32"
            android:gravity="center"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Определение растений с помощью AI"
            android:textSize="13sp"
            android:textColor="#66BB6A"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <!-- Превью изображения -->
        <ImageView
            android:id="@+id/imageView"
            android:layout_width="match_parent"
            android:layout_height="280dp"
            android:scaleType="centerCrop"
            android:background="#C8E6C9"
            android:src="@drawable/ic_launcher_foreground"
            android:contentDescription="Фото растения"
            android:layout_marginBottom="16dp" />

        <!-- Кнопки -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnCamera"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="📷 Камера"
                android:backgroundTint="#388E3C"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btnGallery"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="🖼 Галерея"
                android:backgroundTint="#558B2F"
                android:textColor="#FFFFFF" />

        </LinearLayout>

        <!-- Статус / прогресс -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:visibility="gone"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Загружаю модель TFLite..."
            android:textColor="#555555"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <!-- Результаты распознавания -->
        <LinearLayout
            android:id="@+id/resultsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:elevation="2dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvPlantName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#1B5E20"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/tvPlantSci"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="italic"
                android:textColor="#888888"
                android:layout_marginBottom="4dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvLowConfidence"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#E65100"
                android:layout_marginBottom="4dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvConfidence"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#43A047"
                android:layout_marginBottom="12dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tvOtherResults"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="#757575"
                android:lineSpacingMultiplier="1.4"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Разделитель и кнопка болезней -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#C8E6C9"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Заметили признаки болезни или вредителя?"
            android:textSize="13sp"
            android:textColor="#555"
            android:gravity="center"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnDiagnoseDisease"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔬 Диагностировать болезнь"
            android:backgroundTint="#E64A19"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="16dp"/>

        <Button
           android:id="@+id/btnPlantGuide"
           android:layout_width="match_parent"
           android:layout_height="wrap_content"
           android:text="📖 Справочник растений"
           android:backgroundTint="#1976D2"
           android:textColor="#FFFFFF"
           android:layout_marginBottom="8dp"/>
        <!-- Примечание о модели -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Powered by TensorFlow Lite (MobileNetV2) · Apache 2.0"
            android:textSize="11sp"
            android:textColor="#AAAAAA"
            android:gravity="center"
            android:layout_marginTop="4dp" />

    </LinearLayout>

</ScrollView>
