<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="56dp"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:paddingBottom="20dp">

        <!-- Шапка -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@mipmap/ic_launcher"
                android:layout_marginEnd="12dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PlantVision"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Определение растений"
                    android:textSize="12sp"
                    android:textColor="#4CAF50" />
            </LinearLayout>
        </LinearLayout>

        <!-- Hero -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Познайте\nмир растений"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Сфотографируйте растение — определим вид и оценим его здоровье"
            android:textSize="13sp"
            android:textColor="#5A8A5A"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="20dp" />

        <!-- Карточка с фото -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="260dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="24dp"
            app:cardBackgroundColor="#132013"
            app:cardElevation="0dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <ImageView
                    android:id="@+id/imageView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:contentDescription="Фото растения" />

                <LinearLayout
                    android:id="@+id/photoHint"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="#CC132013">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌿"
                        android:textSize="48sp"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Нажмите «Камера» или «Галерея»"
                        android:textSize="14sp"
                        android:textColor="#4CAF50"
                        android:gravity="center" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:visibility="gone"
                    android:indeterminateTint="#4CAF50" />

            </FrameLayout>
        </androidx.cardview.widget.CardView>

        <!-- Камера / Галерея -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btnCamera"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="📷  Камера"
                android:textSize="14sp"
                android:backgroundTint="#1A2E1A"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btnGallery"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="🖼  Галерея"
                android:textSize="14sp"
                android:backgroundTint="#1A2E1A"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <!-- Статус -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Загружаю модели..."
            android:textColor="#4A6A4A"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginBottom="12dp" />

        <!-- Две кнопки анализа -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnIdentify"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="🌿 Определить\nрастение"
                android:textSize="13sp"
                android:backgroundTint="#1B4D1B"
                android:textColor="#FFFFFF"
                android:enabled="false"
                android:alpha="0.4" />

            <Button
                android:id="@+id/btnDiagnose"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="🩺 Диагностика\nболезней"
                android:textSize="13sp"
                android:backgroundTint="#4D2B00"
                android:textColor="#FFFFFF"
                android:enabled="false"
                android:alpha="0.4" />
        </LinearLayout>

        <!-- РЕЗУЛЬТАТ: ВИД РАСТЕНИЯ -->
        <LinearLayout
            android:id="@+id/resultsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#132013"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🌿 Определённое растение"
                android:textSize="12sp"
                android:textColor="#4CAF50"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tvPlantName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/tvPlantSci"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="italic"
                android:textColor="#557A55"
                android:layout_marginBottom="6dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvConfidence"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="#4CAF50"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvLowConfidence"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#FF7043"
                android:layout_marginBottom="4dp"
                android:visibility="gone" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1E3A1E"
                android:layout_marginVertical="8dp" />

            <TextView
                android:id="@+id/tvOtherResults"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#4A6A4A"
                android:lineSpacingMultiplier="1.4"
                android:visibility="gone" />
        </LinearLayout>

        <!-- РЕЗУЛЬТАТ: ЗДОРОВЬЕ -->
        <LinearLayout
            android:id="@+id/diseaseCardResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A1008"
            android:padding="16dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🩺 Состояние здоровья"
                android:textSize="12sp"
                android:textColor="#FFA726"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tvDiseaseName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvDiseaseConfidence"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#666666"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvPathogen"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="#AAAAAA"
                android:layout_marginBottom="2dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">
                <TextView android:id="@+id/tvSeverity"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:textSize="12sp" android:textColor="#FF7043" />
                <TextView android:id="@+id/tvSpread"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:textSize="12sp" android:textColor="#888888" />
            </LinearLayout>

            <TextView android:id="@+id/tvUrgency"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="13sp" android:textStyle="bold" android:layout_marginBottom="10dp" />

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#2A2010" android:layout_marginBottom="10dp" />

            <LinearLayout android:id="@+id/sectionSymptoms"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginBottom="8dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="🔍 Симптомы" android:textSize="13sp"
                    android:textStyle="bold" android:textColor="#FFA726" android:layout_marginBottom="4dp" />
                <TextView android:id="@+id/tvSymptoms"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textSize="12sp" android:textColor="#AAAAAA" android:lineSpacingMultiplier="1.4" />
            </LinearLayout>

            <LinearLayout android:id="@+id/sectionCauses"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginBottom="8dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="⚡ Причины" android:textSize="13sp"
                    android:textStyle="bold" android:textColor="#FFA726" android:layout_marginBottom="4dp" />
                <TextView android:id="@+id/tvCauses"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textSize="12sp" android:textColor="#AAAAAA" android:lineSpacingMultiplier="1.4" />
            </LinearLayout>

            <LinearLayout android:id="@+id/sectionTreatment"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginBottom="8dp"
                android:background="#1F1A0A" android:padding="10dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="💊 Лечение" android:textSize="13sp"
                    android:textStyle="bold" android:textColor="#FFA726" android:layout_marginBottom="4dp" />
                <TextView android:id="@+id/tvTreatment"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textSize="12sp" android:textColor="#CCCCCC" android:lineSpacingMultiplier="1.5" />
            </LinearLayout>

            <LinearLayout android:id="@+id/sectionPrevention"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:background="#0D1A0D" android:padding="10dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="🛡 Профилактика" android:textSize="13sp"
                    android:textStyle="bold" android:textColor="#4CAF50" android:layout_marginBottom="4dp" />
                <TextView android:id="@+id/tvPrevention"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textSize="12sp" android:textColor="#CCCCCC" android:lineSpacingMultiplier="1.5" />
            </LinearLayout>

            <TextView android:id="@+id/tvDiseaseOther"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="11sp" android:textColor="#444444"
                android:lineSpacingMultiplier="1.4" android:layout_marginTop="8dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Справочник -->
        <Button
            android:id="@+id/btnPlantGuide"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="📖  Справочник растений"
            android:textSize="14sp"
            android:backgroundTint="#132013"
            android:textColor="#4CAF50"
            android:layout_marginBottom="24dp"
            style="@style/Widget.Material3.Button.OutlinedButton" />

    </LinearLayout>
</ScrollView>
